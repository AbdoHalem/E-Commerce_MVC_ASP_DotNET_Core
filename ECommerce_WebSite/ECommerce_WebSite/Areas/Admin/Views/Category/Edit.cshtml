@using ECommerce_WebSite.Areas.Admin.ViewModels
@model CategoryVM
@{
    ViewData["Title"] = "Edit Category";
    var categoriesList = ViewBag.CategoriesList as List<Entities.Models.Category>;
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card box-shadow">
                <div class="card-header bg-warning text-dark">
                    <h4 class="mb-0">Edit Category</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit" method="post">

                        <input type="hidden" asp-for="Id" />

                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3 fw-bold"></div>

                        <div class="form-group mb-3">
                            <label asp-for="Name" class="form-label fw-bold"></label>
                            <input asp-for="Name" class="form-control" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-4">
                            <label asp-for="ParentCategoryId" class="form-label fw-bold"></label>
                            <select asp-for="ParentCategoryId" class="form-select">
                                <option value="">-- No Parent (Make this a Main Category) --</option>
                                @if (categoriesList != null)
                                {
                                    foreach (var cat in categoriesList)
                                    {
                                        <option value="@cat.Id">@cat.Name</option>
                                    }
                                }
                            </select>
                            <span asp-validation-for="ParentCategoryId" class="text-danger"></span>
                        </div>

                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
                            <button type="submit" class="btn btn-warning">Update Category</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
