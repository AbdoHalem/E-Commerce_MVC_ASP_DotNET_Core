@model IEnumerable<Entities.Models.Order>
@{
    ViewData["Title"] = "Manage Orders";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-cart-check"></i> Manage Customer Orders</h2>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">No orders have been placed yet.</div>
    }
    else
    {
        <div class="card box-shadow">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover table-striped mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th>Order Number</th>
                                <th>Date</th>
                                <th>Total Amount</th>
                                <th>Status</th>
                                <th class="text-center">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var order in Model)
                            {
                                <tr>
                                    <td class="align-middle fw-bold text-primary">@order.OrderNumber</td>
                                    <td class="align-middle">@order.OrderDate.ToString("dd MMM yyyy, hh:mm tt")</td>
                                    <td class="align-middle fw-bold text-success">@order.TotalAmount.ToString("C")</td>
                                    <td class="align-middle">
                                        @if (order.Status == Entities.Models.OrderStatus.Pending)
                                        {
                                            <span class="badge bg-warning text-dark">Pending</span>
                                        }
                                        else if (order.Status == Entities.Models.OrderStatus.Processing)
                                        {
                                            <span class="badge bg-info text-dark">Processing</span>
                                        }
                                        else if (order.Status == Entities.Models.OrderStatus.Shipped)
                                        {
                                            <span class="badge bg-primary">Shipped</span>
                                        }
                                        else if (order.Status == Entities.Models.OrderStatus.Delivered)
                                        {
                                            <span class="badge bg-success">Delivered</span>
                                        }
                                        else if (order.Status == Entities.Models.OrderStatus.Cancelled)
                                        {
                                            <span class="badge bg-danger">Cancelled</span>
                                        }
                                    </td>
                                    <td class="align-middle text-center">
                                        <a asp-action="Details" asp-route-id="@order.Id" class="btn btn-outline-dark btn-sm">
                                            <i class="bi bi-eye"></i> View Details
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>