@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container mt-5">
    <div class="d-flex align-items-center mb-5 border-bottom pb-3">
        <i class="bi bi-speedometer2 display-6 text-primary me-3"></i>
        <h2 class="mb-0">Control Panel</h2>
    </div>

    <div class="row">
        <div class="col-md-4 mb-4">
            <div class="card text-center box-shadow h-100 border-primary">
                <div class="card-body p-4 d-flex flex-column">
                    <i class="bi bi-tags display-3 text-primary mb-3"></i>
                    <h4 class="card-title fw-bold">Categories</h4>
                    <p class="card-text text-muted mb-4">Add, edit, or delete product categories.</p>
                    <a asp-controller="Category" asp-action="Index" class="btn btn-outline-primary w-100 fw-bold mt-auto">Manage Categories</a>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card text-center box-shadow h-100 border-success">
                <div class="card-body p-4 d-flex flex-column">
                    <i class="bi bi-box-seam display-3 text-success mb-3"></i>
                    <h4 class="card-title fw-bold">Products</h4>
                    <p class="card-text text-muted mb-4">Manage your inventory, prices, and images.</p>
                    <a asp-controller="Product" asp-action="Index" class="btn btn-outline-success w-100 fw-bold mt-auto">Manage Products</a>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card text-center box-shadow h-100 border-warning">
                <div class="card-body p-4 d-flex flex-column">
                    <i class="bi bi-cart-check display-3 text-warning mb-3"></i>
                    <h4 class="card-title fw-bold">Orders</h4>
                    <p class="card-text text-muted mb-4">View customer orders and update statuses.</p>
                    <a asp-controller="Order" asp-action="Index" class="btn btn-outline-warning text-dark w-100 fw-bold mt-auto">Manage Orders</a>
                </div>
            </div>
        </div>
    </div>
</div>