@model AddressVM
@{
    ViewData["Title"] = "Create";
    // Get the return URL from ViewData if it exists
    var returnUrl = ViewData["ReturnUrl"] as string;
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card box-shadow">
                <div class="card-header bg-dark text-white">
                    <h4 class="mb-0">Add a New Shipping Address</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create" asp-route-returnUrl="@returnUrl" method="post">

                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3 fw-bold"></div>

                        <div class="row">
                            <div class="col-md-6 form-group mb-3">
                                <label asp-for="Country" class="form-label fw-bold"></label>
                                <input asp-for="Country" class="form-control" placeholder="e.g. Egypt" />
                                <span asp-validation-for="Country" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 form-group mb-3">
                                <label asp-for="City" class="form-label fw-bold"></label>
                                <input asp-for="City" class="form-control" placeholder="e.g. Alexandria" />
                                <span asp-validation-for="City" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="Street" class="form-label fw-bold"></label>
                            <input asp-for="Street" class="form-control" placeholder="123 Main St, Apartment 4B" />
                            <span asp-validation-for="Street" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="Zip" class="form-label fw-bold"></label>
                            <input asp-for="Zip" class="form-control" placeholder="e.g. 21511" />
                            <span asp-validation-for="Zip" class="text-danger"></span>
                        </div>

                        <div class="form-check mb-4">
                            <input asp-for="IsDefault" class="form-check-input" />
                            <label asp-for="IsDefault" class="form-check-label"></label>
                        </div>

                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
                            <button type="submit" class="btn btn-success">Save Address</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

