@model IEnumerable<Address>
@{
    ViewData["Title"] = "Addresses";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Saved Addresses</h2>
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show mb-4 me-3" role="alert">
                <i class="bi bi-exclamation-triangle-fill"></i> @TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
                <i class="bi bi-check-circle-fill"></i> @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        
        <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-circle"></i> Add New Address</a>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            You don't have any saved addresses yet. Please add one to proceed with checkout.
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var address in Model)
            {
                <div class="col-md-4 mb-4">
                    <div class="card box-shadow h-100 @(address.IsDefault ? "border-primary" : "")">
                        <div class="card-header @(address.IsDefault ? "bg-primary text-white" : "bg-light") d-flex justify-content-between">
                            <h5 class="mb-0">@address.City</h5>
                            @if (address.IsDefault)
                            {
                                <span class="badge bg-light text-primary">Default</span>
                            }
                        </div>
                        <div class="card-body">
                            <p class="card-text mb-1"><strong>Country:</strong> @address.Country</p>
                            <p class="card-text mb-1"><strong>Street:</strong> @address.Street</p>
                            <p class="card-text mb-0"><strong>ZIP Code:</strong> @address.Zip</p>
                        </div>
                        <div class="card-footer bg-white border-top-0 text-end">
                            <form asp-action="Delete" method="post" class="d-inline">
                                <input type="hidden" name="id" value="@address.Id" />
                                <button type="submit" class="btn btn-outline-danger btn-sm" onclick="return confirm('Are you sure you want to delete this address?');">Delete</button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

