@model LoginVM
@{
    ViewData["Title"] = "Login to Your Account";
    string? returnUrl = ViewData["ReturnUrl"] as string;
    // Tell the Layout to hide the Navbar
    ViewData["HideNavbar"] = true;
}

<div class="container mt-5">
    <div class="row justify-content-center text-center mb-4">
        <div class="col-12">
            <a asp-controller="Catalog" asp-action="Index">
                <img src="~/images/logo1.jpg" alt="Halem Store Logo" style="height: 80px; width: auto; mix-blend-mode: multiply; object-fit: contain;" />
            </a>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card box-shadow">
                <div class="card-header bg-primary text-white text-center">
                    <h4 class="mb-0">Welcome Back</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Login" asp-route-returnUrl="@returnUrl" method="post">

                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3 fw-bold"></div>

                        <div class="form-group mb-3">
                            <label asp-for="Email" class="form-label fw-bold"></label>
                            <input asp-for="Email" class="form-control" placeholder="name@example.com" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="Password" class="form-label fw-bold"></label>
                            <input asp-for="Password" class="form-control" placeholder="********" />
                            <span asp-validation-for="Password" class="text-danger"></span>
                        </div>

                        <div class="form-check mb-4">
                            <input asp-for="RememberMe" class="form-check-input" />
                            <label asp-for="RememberMe" class="form-check-label"></label>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 btn-lg">Login</button>
                    </form>
                </div>
                <div class="card-footer text-center bg-light">
                    <p class="mb-0">Don't have an account? <a asp-action="Register" class="text-primary fw-bold">Create one now</a></p>
                </div>
            </div>
        </div>
    </div>
</div>
