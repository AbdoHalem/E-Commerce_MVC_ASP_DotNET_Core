@model RegisterVM
@{
    ViewData["Title"] = "Register";
    // Tell the Layout to hide the Navbar
    ViewData["HideNavbar"] = true;
}

<div class="container mt-5">
    <div class="row justify-content-center text-center mb-4">
        <div class="col-12">
            <a asp-controller="Catalog" asp-action="Index">
                <img src="~/images/logo1.jpg" alt="Halem Store Logo" style="height: 80px; width: auto; mix-blend-mode: multiply; object-fit: contain;" />
            </a>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card box-shadow">
                <div class="card-header bg-primary text-white text-center">
                    <h4 class="mb-0">Create a New Account</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Register" method="post">

                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3 fw-bold"></div>

                        <div class="form-group mb-3">
                            <label asp-for="FullName" class="form-label fw-bold"></label>
                            <input asp-for="FullName" class="form-control" placeholder="e.g. Abdo Halem" />
                            <span asp-validation-for="FullName" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="Email" class="form-label fw-bold"></label>
                            <input asp-for="Email" class="form-control" placeholder="name@example.com" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="Password" class="form-label fw-bold"></label>
                            <input asp-for="Password" class="form-control" placeholder="********" />
                            <span asp-validation-for="Password" class="text-danger"></span>
                            <small class="text-muted">Password must have at least one uppercase, one lowercase, one number, and one special character.</small>
                        </div>

                        <div class="form-group mb-4">
                            <label asp-for="ConfirmPassword" class="form-label fw-bold"></label>
                            <input asp-for="ConfirmPassword" class="form-control" placeholder="********" />
                            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 btn-lg">Register Now</button>
                    </form>
                </div>
                <div class="card-footer text-center bg-light">
                    <p class="mb-0">Already have an account? <a asp-action="Login" class="text-primary fw-bold">Login here</a></p>
                </div>
            </div>
        </div>
    </div>
</div>

