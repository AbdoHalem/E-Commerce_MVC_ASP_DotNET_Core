@model ECommerce_WebSite.Models.ViewModels.ProductListVM
@{
    ViewData["Title"] = "Product Catalog";
}

<div class="row mt-4">
    <div class="col-md-3 mb-4">
        <div class="card box-shadow">
            <div class="card-header bg-dark text-white fw-bold">
                <i class="bi bi-list-ul"></i> Categories
            </div>
            <ul class="list-group list-group-flush">

                <li class="list-group-item @(Model.CurrentCategoryId == null ? "active" : "")">
                    <a asp-action="Index"
                       asp-route-q="@Model.SearchQuery"
                       asp-route-sort="@Model.CurrentSort"
                       class="text-decoration-none @(Model.CurrentCategoryId == null ? "text-white fw-bold" : "text-dark")">
                        All Products
                    </a>
                </li>

                @foreach (var cat in Model.Categories)
                {
                    <li class="list-group-item @(Model.CurrentCategoryId == cat.Id ? "active" : "")">
                        <a asp-action="Index"
                           asp-route-categoryId="@cat.Id"
                           asp-route-q="@Model.SearchQuery"
                           asp-route-sort="@Model.CurrentSort"
                           class="text-decoration-none @(Model.CurrentCategoryId == cat.Id ? "text-white fw-bold" : "text-dark")">
                            @cat.Name
                        </a>
                    </li>
                }
            </ul>
        </div>
    </div>

    <div class="col-md-9">

        <form asp-action="Index" method="get" class="mb-4">
            @if (Model.CurrentCategoryId.HasValue)
            {
                <input type="hidden" name="categoryId" value="@Model.CurrentCategoryId" />
            }

            <div class="row g-2">
                <div class="col-md-8">
                    <div class="input-group box-shadow h-100">
                        <input type="text" name="q" value="@Model.SearchQuery" class="form-control" placeholder="Search for products...">
                        <button type="submit" class="btn btn-primary px-4"><i class="bi bi-search"></i> Search</button>

                        @if (!string.IsNullOrEmpty(Model.SearchQuery))
                        {
                            <a asp-action="Index" asp-route-categoryId="@Model.CurrentCategoryId" asp-route-sort="@Model.CurrentSort" class="btn btn-outline-secondary">Clear</a>
                        }
                    </div>
                </div>

                <div class="col-md-4">
                    <select name="sort" class="form-select box-shadow h-100 fw-bold text-secondary" onchange="this.form.submit()">
                        <option value="" selected="@(string.IsNullOrEmpty(Model.CurrentSort) ? "selected" : null)">Sort by: Newest First</option>
                        <option value="price_asc" selected="@(Model.CurrentSort == "price_asc" ? "selected" : null)">Price: Low to High</option>
                        <option value="price_desc" selected="@(Model.CurrentSort == "price_desc" ? "selected" : null)">Price: High to Low</option>
                        <option value="name_asc" selected="@(Model.CurrentSort == "name_asc" ? "selected" : null)">Name: A to Z</option>
                    </select>
                </div>
            </div>
        </form>

        @if (!Model.Products.Any())
        {
            <div class="alert alert-warning text-center p-5 box-shadow">
                <h4><i class=\"bi bi-emoji-frown\"></i> No products found.</h4>
                <p>Try adjusting your search or filtering by a different category.</p>
            </div>
        }
        else
        {
            <div class="row">
                @foreach (var product in Model.Products)
                {
                    <div class="col-md-4 mb-4">
                        <div class="card h-100 box-shadow">
                            <img src="@product.ImageUrl" class="card-img-top p-3" alt="@product.Name" style="height: 200px; object-fit: contain;">
                            <div class="card-body d-flex flex-column">
                                <h5 class="card-title text-truncate" title="@product.Name">@product.Name</h5>
                                <h6 class="card-subtitle mb-3 text-success fw-bold fs-5">@product.Price.ToString("C")</h6>

                                <div class="mt-auto d-flex justify-content-between align-items-center">
                                    <a asp-action="Details" asp-route-id="@product.Id" class="btn btn-outline-dark btn-sm">Details</a>

                                    @if (product.StockQuantity > 0)
                                    {
                                        <form asp-controller="Cart" asp-action="Add" method="post" class="m-0">
                                            <input type="hidden" name="productId" value="@product.Id" />
                                            <button type="submit" class="btn btn-primary btn-sm"><i class="bi bi-cart-plus"></i> Add</button>
                                        </form>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Out of Stock</span>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }

        @if (Model.TotalPages > 1)
        {
            <nav class="mt-4">
                <ul class="pagination justify-content-center box-shadow">

                    <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                        <a class="page-link" asp-action="Index"
                           asp-route-page="@(Model.CurrentPage - 1)"
                           asp-route-categoryId="@Model.CurrentCategoryId"
                           asp-route-q="@Model.SearchQuery"
                           asp-route-sort="@Model.CurrentSort">Previous</a>
                    </li>

                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                            <a class="page-link" asp-action="Index"
                               asp-route-page="@i"
                               asp-route-categoryId="@Model.CurrentCategoryId"
                               asp-route-q="@Model.SearchQuery"
                               asp-route-sort="@Model.CurrentSort">@i</a>
                        </li>
                    }

                    <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                        <a class="page-link" asp-action="Index"
                           asp-route-page="@(Model.CurrentPage + 1)"
                           asp-route-categoryId="@Model.CurrentCategoryId"
                           asp-route-q="@Model.SearchQuery"
                           asp-route-sort="@Model.CurrentSort">Next</a>
                    </li>
                </ul>
            </nav>
        }
    </div>
</div>