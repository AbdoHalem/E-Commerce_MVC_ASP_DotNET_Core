@model ProductDetailsVM
@{
    ViewBag.Title = Model.Name;
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-6 mb-4">
            <img src="@Model.ImageUrl" class="img-fluid rounded box-shadow h-50" alt="@Model.Name">
        </div>

        <div class="col-md-6">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-action="Index">Catalog</a></li>
                    <li class="breadcrumb-item active" aria-current="page">@Model.CategoryName</li>
                </ol>
            </nav>

            <h1 class="display-5">@Model.Name</h1>
            <p class="text-muted">SKU: @Model.SKU</p>

            <h2 class="text-primary fw-bold my-3">@Model.Price.ToString("C")</h2>

            <hr />

            <div class="my-4">
                @if (Model.StockQuantity > 0)
                {
                    <span class="badge bg-success fs-6 mb-3">In Stock (@Model.StockQuantity available)</span>

                    <form asp-controller="Cart" asp-action="Add" method="post" class="d-flex align-items-center">
                        <input type="hidden" name="productId" value="@Model.Id" />

                        <label class="me-2 fw-bold">Quantity:</label>
                        <input type="number" name="quantity" value="1" min="1" max="@Model.StockQuantity" class="form-control w-25 me-3" />

                        <button type="submit" class="btn btn-primary btn-lg">Add to Cart</button>
                    </form>
                }
                else
                {
                    <span class="badge bg-danger fs-6">Out of Stock</span>
                    <button class="btn btn-secondary btn-lg mt-3" disabled>Add to Cart</button>
                }
            </div>

            <div class="mt-5">
                <h4>Product Description</h4>
                <p class="lead fs-6">@Model.Description</p>
            </div>
        </div>
    </div>
</div>