@model IEnumerable<Order>
@{
    ViewData["Title"] = "Orders";
}

<div class="container mt-5">
    <h2 class="mb-4">Order History</h2>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
            <i class="bi bi-check-circle-fill"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            You haven't placed any orders yet. <a asp-controller="Catalog" asp-action="Index">Start shopping now!</a>
        </div>
    }
    else
    {
        <div class="table-responsive box-shadow">
            <table class="table table-hover table-bordered mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Order Number</th>
                        <th>Date</th>
                        <th>Status</th>
                        <th>Total Amount</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model)
                    {
                        <tr>
                            <td class="align-middle fw-bold">@order.OrderNumber</td>
                            <td class="align-middle">@order.OrderDate.ToString("dd MMM yyyy, hh:mm tt")</td>

                            <td class="align-middle">
                                @if (order.Status == Entities.Models.OrderStatus.Pending)
                                {
                                    <span class="badge bg-warning text-dark">Pending</span>
                                }
                                else if (order.Status == Entities.Models.OrderStatus.Cancelled)
                                {
                                    <span class="badge bg-danger">Cancelled</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">@order.Status</span>
                                }
                            </td>

                            <td class="align-middle fw-bold text-success">@order.TotalAmount.ToString("C")</td>

                            <td class="align-middle text-center d-flex justify-content-center gap-2 border-0">
                                <a asp-action="Details" asp-route-id="@order.Id" class="btn btn-outline-primary btn-sm">View Details</a>

                                @if (order.Status == Entities.Models.OrderStatus.Pending)
                                {
                                    <form asp-action="Cancel" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to cancel this order? This action cannot be undone.');">
                                        <input type="hidden" name="id" value="@order.Id" />
                                        <button type="submit" class="btn btn-outline-danger btn-sm">Cancel Order</button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

